# Google Generative AI (Gemini) API key.
# Create one at https://aistudio.google.com/app/apikey
# Used by @ai-sdk/google to call Gemini directly from the API routes.
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional. Default: gemini-2.5-flash-image (see https://ai.google.dev/gemini-api/docs/models).
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
